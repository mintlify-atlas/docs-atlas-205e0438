  "keyFeatures": [
    "Real-time voice conversation with AI using any LLM backend (Ollama, OpenAI, Claude, Gemini, etc.)",
    "Live2D animated avatar with expression and motion control",
    "Voice interruption without headphones via Silero VAD",
    "Completely offline operation — no internet required when using local models",
    "Cross-platform: Windows, macOS, Linux with GPU and CPU support",
    "Desktop pet mode with transparent background, global top-most, and click-through",
    "Visual perception — AI can see via camera or screen capture",
    "20+ TTS backends including voice cloning (GPT-SoVITS, CosyVoice, Fish Audio)",
    "10+ ASR backends including Sherpa-ONNX, Faster-Whisper, Azure ASR",
    "MCP (Model Context Protocol) tool integration for LLM tool use",
    "Group conversation mode with multiple AI participants",
    "Character customization via YAML config files and Live2D model import",
    "TTS translation support (e.g., converse in English, AI speaks Japanese)",
    "Live streaming integration (Bilibili)"
  ],
  "publicApiSurface": [
    "WebSocket endpoint: ws://localhost:12393/client-ws (main client connection)",
    "WebSocket endpoint: ws://localhost:12393/proxy-ws (proxy connection)",
    "HTTP server: GET / (serves web frontend)",
    "HTTP server: GET /live2d-models (serves Live2D model assets)",
    "agent_factory.AgentFactory.create_agent(config, ...)",
    "asr_factory.ASRFactory.get_asr_engine(config)",
    "tts_factory.TTSFactory.get_tts_engine(config)",
    "agent_interface.AgentInterface (base class for custom agents)",
    "asr_interface.ASRInterface (base class for custom ASR engines)",
    "tts_interface.TTSInterface (base class for custom TTS engines)",
    "service_context.ServiceContext (dependency injection container)",
    "config_manager (type-safe YAML configuration classes)",
    "conf.yaml (user configuration file)",
    "characters/*.yaml (character definition files)"
  ]
}
